{
	"name": "@videosailor/n8n-nodes-videosailor",
	"version": "1.1.3",
	"description": "n8n community node to download, transcribe, trim, cut, resize, and subtitle videos via VideoSailor",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"video",
		"transcription",
		"media",
		"download",
		"subtitles"
	],
	"license": "MIT",
	"homepage": "https://videosailor.com",
	"author": {
		"name": "VideoSailor",
		"email": "support@videosailor.com",
		"url": "https://videosailor.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/VideoSailor/n8n-nodes-videosailor"
	},
	"main": "dist/nodes/VideoSailor/VideoSailor.node.js",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes/**/*.ts credentials/**/*.ts package.json",
		"lintfix": "eslint nodes credentials package.json --fix"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/VideoSailorApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/VideoSailor/VideoSailor.node.js"
		]
	},
	"devDependencies": {
		"@types/node": "^20.15.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.56.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "*",
		"prettier": "^3.2.0",
		"typescript": "~5.4.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
